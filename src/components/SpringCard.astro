---
interface Props {
  title: string;
  description: string;
  drive_time_label: string;
  cost: string;
  rating: number;
  type: string;
  slug: string;
  best_season: string[];
  crowd_level: string;
  last_verified: string;
  featured?: boolean;
}

const {
  title, description, drive_time_label, cost, rating,
  type, slug, best_season, crowd_level, last_verified, featured = false
} = Astro.props;

const crowdColor = {
  low: 'text-green-700 bg-green-50',
  medium: 'text-yellow-700 bg-yellow-50',
  high: 'text-red-700 bg-red-50',
}[crowd_level];

const typeLabel = {
  commercial: 'Commercial Pool',
  primitive: 'Primitive / Free',
  resort: 'Resort',
  'clothing-optional': 'Clothing Optional',
}[type];

const stars = '★'.repeat(Math.round(rating)) + '☆'.repeat(5 - Math.round(rating));
---

<a href={`/springs/${slug}`}
   class={`block bg-white rounded-xl border hover:shadow-md transition-shadow p-5 ${featured ? 'border-blue-300 ring-1 ring-blue-200' : 'border-stone-200'}`}>

  {featured && (
    <span class="inline-block text-xs font-semibold text-blue-700 bg-blue-50 px-2 py-0.5 rounded mb-2">
      Staff Pick
    </span>
  )}

  <div class="flex items-start justify-between gap-2 mb-1">
    <h3 class="font-bold text-stone-900 text-lg leading-tight">{title}</h3>
    <span class="text-amber-500 text-sm whitespace-nowrap">{stars}</span>
  </div>

  <p class="text-stone-500 text-sm mb-3 line-clamp-2">{description}</p>

  <div class="flex flex-wrap gap-2 text-xs">
    <span class="bg-stone-100 text-stone-600 px-2 py-1 rounded">
      🚗 {drive_time_label}
    </span>
    <span class="bg-stone-100 text-stone-600 px-2 py-1 rounded">
      💰 {cost}
    </span>
    <span class={`px-2 py-1 rounded ${crowdColor}`}>
      👥 {crowd_level} crowds
    </span>
    <span class="bg-stone-100 text-stone-600 px-2 py-1 rounded">
      {typeLabel}
    </span>
  </div>

  <div class="mt-3 flex items-center justify-between">
    <span class="text-xs text-stone-400">Best: {best_season.join(', ')}</span>
    <span class="text-xs text-stone-400">Verified {last_verified}</span>
  </div>

</a>
