---
interface Props {
  title: string;
  description: string;
  drive_time_label: string;
  cost: string;
  rating: number;
  type: string;
  slug: string;
  best_season: string[];
  crowd_level: string;
  last_verified: string;
  hero_image?: string;
  featured?: boolean;
}

const {
  title, description, drive_time_label, cost, rating,
  type, slug, best_season, crowd_level, last_verified,
  hero_image, featured = false
} = Astro.props;

const crowdColor = {
  low: 'text-green-700 bg-green-50',
  medium: 'text-yellow-700 bg-yellow-50',
  high: 'text-red-700 bg-red-50',
}[crowd_level];

const typeLabel = {
  commercial: 'Commercial Pool',
  primitive: 'Primitive / Free',
  resort: 'Resort',
  'clothing-optional': 'Clothing Optional',
}[type];

// Unique gradient per spring type: looks great until real photos are added
const gradients = {
  commercial:          'from-blue-400 to-cyan-500',
  primitive:           'from-emerald-400 to-teal-600',
  resort:              'from-violet-400 to-indigo-500',
  'clothing-optional': 'from-amber-400 to-orange-500',
};
const gradient = gradients[type] ?? 'from-blue-400 to-cyan-500';

const stars = '★'.repeat(Math.round(rating)) + '☆'.repeat(5 - Math.round(rating));
---

<a href={`/springs/${slug}`}
   class={`block bg-white rounded-xl border overflow-hidden hover:shadow-lg transition-shadow ${featured ? 'border-blue-300 ring-1 ring-blue-200' : 'border-stone-200'}`}>

  <!-- Photo / gradient hero -->
  <div class="relative h-44 overflow-hidden">
    {hero_image ? (
      <img
        src={hero_image}
        alt={title}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    ) : (
      <div class={`w-full h-full bg-gradient-to-br ${gradient} flex items-end p-3`}>
        <span class="text-white/70 text-xs font-medium uppercase tracking-widest">
          {typeLabel}
        </span>
      </div>
    )}

    <!-- Rating badge overlaid on photo -->
    <div class="absolute top-3 right-3 bg-black/50 backdrop-blur-sm text-white text-xs font-bold px-2 py-1 rounded-full">
      {stars}
    </div>

    {featured && (
      <div class="absolute top-3 left-3 bg-blue-600 text-white text-xs font-semibold px-2 py-1 rounded-full">
        Staff Pick
      </div>
    )}
  </div>

  <!-- Card body -->
  <div class="p-4">
    <h3 class="font-bold text-stone-900 text-base leading-tight mb-1">{title}</h3>
    <p class="text-stone-500 text-sm mb-3 line-clamp-2">{description}</p>

    <div class="flex flex-wrap gap-2 text-xs">
      <span class="bg-stone-100 text-stone-600 px-2 py-1 rounded">
        🚗 {drive_time_label}
      </span>
      <span class="bg-stone-100 text-stone-600 px-2 py-1 rounded">
        💰 {cost}
      </span>
      <span class={`px-2 py-1 rounded ${crowdColor}`}>
        👥 {crowd_level} crowds
      </span>
    </div>

    <div class="mt-3 flex items-center justify-between">
      <span class="text-xs text-stone-400">Best: {best_season.join(', ')}</span>
      <span class="text-xs text-stone-400">Verified {last_verified}</span>
    </div>
  </div>

</a>
